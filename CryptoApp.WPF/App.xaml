<Application x:Class="CryptoApp.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CryptoApp.WPF.Views"
             xmlns:vm="clr-namespace:CryptoApp.ViewModels;assembly=CryptoApp.ViewModels"
             StartupUri="/Views/MainWindow.xaml">
    
    <Application.Resources>
         <ResourceDictionary>
             <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                 <views:HomeView />
             </DataTemplate>
         </ResourceDictionary>
    </Application.Resources>
</Application>
